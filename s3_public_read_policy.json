{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PublicReadPp06",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::s3ooi/pp06/*"
        },
        {
            "Sid": "PublicListPp06",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:ListBucket",
            "Resource": "arn:aws:s3:::s3ooi",
            "Condition": {
                "StringLike": {
                    "s3:prefix": "pp06/*"
                }
            }
        }
    ]
}
